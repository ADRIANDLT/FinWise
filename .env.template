# ---------------------------------------------------------------
# FinWise Environment Variables (consumed by docker-compose.yml)
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it contains secrets.
# ---------------------------------------------------------------

# --- FinWise Azure AI Foundry (required) ---
FINWISE_AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
FINWISE_AZURE_AI_FOUNDRY_LLM_DEPLOYMENT_NAME=your-deployment-name

# --- Shared Azure service principal (required for FinWise Foundry LLM and optional for Stock Agent) ---
FINWISE_AZURE_TENANT_ID=
FINWISE_AZURE_CLIENT_ID=
FINWISE_AZURE_CLIENT_SECRET=

# --- Stock Agent (optional — leave empty to disable; reuses FINWISE_AZURE_AI_FOUNDRY_PROJECT_ENDPOINT) ---
STOCK_AGENT_NAME=

# --- Data store master toggle ---
# "true"  = force ALL stores to in-memory (no infra needed)
# "false" = each store decides via its own Enabled flag below
FINWISE_FORCE_IN_MEMORY_DATA=false

# --- CosmosDB user profile store (overrides appsettings.json) ---
FINWISE_COSMOSDB_ENABLED=true
FINWISE_COSMOSDB_ENDPOINT=https://finwise-cosmosdb-emulator:8081/
FINWISE_COSMOSDB_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
FINWISE_COSMOSDB_DATABASE_NAME=FinWise
FINWISE_COSMOSDB_CONTAINER_NAME=UserProfiles
FINWISE_COSMOSDB_ALLOW_INSECURE_TLS=true

# --- Redis session store (overrides appsettings.json) ---
FINWISE_REDIS_ENABLED=true
FINWISE_REDIS_CONNECTION_STRING=finwise-redis:6379
FINWISE_REDIS_SESSION_TTL_MINUTES=1440
