<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <ResultsDirectory>TestResults</ResultsDirectory>
    <EnvironmentVariables>
      <FINWISE_FORCE_IN_MEMORY_DATA>false</FINWISE_FORCE_IN_MEMORY_DATA>
      <FINWISE_COSMOSDB_ENABLED>true</FINWISE_COSMOSDB_ENABLED>
      <FINWISE_COSMOSDB_ENDPOINT>https://localhost:8081/</FINWISE_COSMOSDB_ENDPOINT>
      <FINWISE_COSMOSDB_KEY>C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==</FINWISE_COSMOSDB_KEY>
      <FINWISE_COSMOSDB_DATABASE_NAME>FinWise</FINWISE_COSMOSDB_DATABASE_NAME>
      <FINWISE_COSMOSDB_CONTAINER_NAME>UserProfiles</FINWISE_COSMOSDB_CONTAINER_NAME>
      <FINWISE_COSMOSDB_ALLOW_INSECURE_TLS>true</FINWISE_COSMOSDB_ALLOW_INSECURE_TLS>
      <FINWISE_REDIS_ENABLED>true</FINWISE_REDIS_ENABLED>
      <FINWISE_REDIS_CONNECTION_STRING>localhost:6379</FINWISE_REDIS_CONNECTION_STRING>
      <FINWISE_REDIS_SESSION_TTL_MINUTES>1440</FINWISE_REDIS_SESSION_TTL_MINUTES>
      <FINWISE_MCP_URL>http://localhost:5000</FINWISE_MCP_URL>
    </EnvironmentVariables>
  </RunConfiguration>
</RunSettings>
