# ---------------------------------------------------------------
# FinWise — Azure Overrides Template
# Layers on TOP of .env (base) — only define vars you want to override.
# Vars not listed here fall through to .env values.
#
# Copy this file to .env.azure and fill in your values.
# NEVER commit the .env.azure file — it contains secrets.
#
# Usage with Docker Compose (must pass BOTH files):
#   docker compose -f docker-compose.finwise.yml --env-file .env --env-file .env.azure up -d
# ---------------------------------------------------------------

# --- CosmosDB user profile store (Azure-hosted) ---
FINWISE_COSMOSDB_ENDPOINT=https://<your-account>.documents.azure.com:443/
FINWISE_COSMOSDB_KEY=your-cosmosdb-primary-key-xxxxxxxxxxxxxxxxxxxxxxxxxxx
FINWISE_COSMOSDB_ALLOW_INSECURE_TLS=false

# --- Redis session store (Azure Managed Redis — Plaintext, Access Key auth) ---
# Endpoint: <name>.<region>.redis.azure.net:10000
# Get your access key from: Azure Portal → your Redis instance → Settings → Authentication → Access keys
FINWISE_REDIS_CONNECTION_STRING=finwise-managed-redis-poc.eastus.redis.azure.net:10000,password=your-redis-access-key,ssl=False,abortConnect=False
